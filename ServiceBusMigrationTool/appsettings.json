{
  "DryRun": false,
  "StateFilePath": "migration-state.json",
  "FreshRun": false,
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Azure": "Warning"
      }
    }
  },
  "NamespaceMigration": {
    "SourceConnectionString": "<source-namespace-connection-string>",
    "DestinationConnectionString": "<destination-namespace-connection-string>",
    "BatchSize": 10000,
    "MaxConcurrency": 5
  },
  "ServiceBusCopy": {
    "Operations": [
      {
        "Source": {
          "ConnectionString": "<source-connection-string>",
          "QueueName": "<source-queue-name>"
        },
        "Destination": {
          "ConnectionString": "<destination-connection-string>",
          "QueueName": "<destination-queue-name>"
        }
      },
      {
        "Source": {
          "ConnectionString": "<source-connection-string>",
          "TopicName": "<source-topic-name>",
          "SubscriptionName": "<source-subscription-name>"
        },
        "Destination": {
          "ConnectionString": "<destination-connection-string>",
          "TopicName": "<destination-topic-name>"
        }
      }
    ]
  }
}
